{
	"lsp": {
		"biome": {
			"settings": {
				"require_config_file": true
			}
		}
	},
	"languages": {
		"Svelte": {
			"language_servers": ["!biome", "..."],
			"formatter": "language_server",
			"format_on_save": "on"
		},
		"JavaScript": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			},
			"format_on_save": "on"
		},
		"TypeScript": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			},
			"format_on_save": "on"
		},
		"JSX": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			},
			"format_on_save": "on"
		},
		"TSX": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			},
			"format_on_save": "on"
		},
		"CSS": {
			"formatter": {
				"language_server": {
					"name": "biome"
				}
			},
			"format_on_save": "on"
		}
	}
}
